// ══════════════════════════════════════════════════════════════
// ═══  ALL FREQUENCIES FLOW — AUDIO-REACTIVE ENGINE  ═══
// ══════════════════════════════════════════════════════════════
// (Identical audio analysis engine from CPU version — only rendering changed)

(function() {
  let flowActive = false;
  let audioCtx = null, analyser = null, analyserWave = null, mediaStream = null;
  let freqDataA = null, timeDataA = null;
  let spectrumBars = [];
  const HISTORY_FRAMES = 60, LONG_HISTORY = 900;
  let energyHistory=[], bandHistory={subBass:[],bass:[],lowMid:[],mid:[],highMid:[],high:[],brilliance:[]};
  let beatCooldown=0, lastBeatTime=0, beatInterval=0, bpm=0, beatStrength=0;
  let spectralCentroid=0, spectralFlux=0, prevSpectrum=null, dominantFreq=0, zeroCrossingRate=0;
  let flow={freq:432,mutRate:1,depth:5,density:6,chroma:6,juliaModR:0,juliaModI:0,coreFlash:0,particleBurst:0,hueShift:0,trailFade:0.12,spiralTwist:0,waveWarp:0,entityBlend:'',entityStrength:0};

  // ── SETTINGS STATE ──
  const flowSettings = {
    timeBufSec: 15,        // entity resonance history window (seconds)
    beatSensitivity: 0.12, // beat detection spike threshold
    bpmSync: false,        // lock mutation rate to BPM
    bpmScale: 1.0,         // BPM→mutRate scale (120bpm × scale = mutRate)
    pitchColorStr: 1.0,    // spectral centroid → hue shift strength
    reactiveness: 0.5,     // 0=smooth 1=snappy
    jumpiness: 0.5,        // beat transient intensity
    epilepsySafe: false,   // disable flash, cap core burst
  };

  window.toggleFlowSettings = function() {
    const panel = document.getElementById('flowSettingsPanel');
    const btn = document.getElementById('flowSettingsToggle');
    if (!panel) return;
    panel.classList.toggle('open');
    btn.classList.toggle('active', panel.classList.contains('open'));
  };
  window.toggleFspBpmSync = function() {
    flowSettings.bpmSync = !flowSettings.bpmSync;
    const btn = document.getElementById('fspBpmSyncBtn');
    if (btn) btn.classList.toggle('on', flowSettings.bpmSync);
  };
  window.toggleFspEpilepsy = function() {
    flowSettings.epilepsySafe = !flowSettings.epilepsySafe;
    const btn = document.getElementById('fspEpiBtn');
    if (btn) btn.classList.toggle('on', flowSettings.epilepsySafe);
  };

  // ── AUTO-DRIVE STATE ──
  const autoDrive = {
    enabled: false,
    intelligence: 0.5,
    chaosPhase: Math.random() * 100,
    harmonicTarget: null,
    harmonicStrength: 0,
    dominant: '',
    agents: {
      fluid:    { name:'FLUID',    color:'#00ffff', weight:0.5, params:{} },
      beat:     { name:'BEAT LOCK',color:'#ff00ff', weight:0.5, params:{} },
      spectral: { name:'SPECTRAL', color:'#bb00ff', weight:0.5, params:{} },
      chaos:    { name:'CHAOS',    color:'#ff3366', weight:0.2, params:{} },
      harmonic: { name:'HARMONIC', color:'#ffaa00', weight:0.3, params:{} },
    }
  };

  window.toggleAutoDrive = function() {
    autoDrive.enabled = !autoDrive.enabled;
    const btn = document.getElementById('adMasterBtn');
    const dom = document.getElementById('adDominant');
    if(btn) {
      btn.style.borderColor = autoDrive.enabled ? 'rgba(255,150,0,0.7)' : 'rgba(255,150,0,0.25)';
      btn.style.color = autoDrive.enabled ? 'rgba(255,200,80,1)' : 'rgba(255,180,80,0.7)';
      btn.querySelector('.fsp-dot').style.background = autoDrive.enabled ? '#ffaa00' : 'rgba(255,150,0,0.2)';
      btn.querySelector('.fsp-dot').style.boxShadow = autoDrive.enabled ? '0 0 10px #ffaa00' : 'none';
    }
    if(dom) dom.style.color = autoDrive.enabled ? 'rgba(255,180,80,0.9)' : 'rgba(255,150,0,0)';
  };

  // ── AGENT COMPUTE FUNCTIONS ──
  function computeAgents(bands, totalEnergy) {
    const ad = autoDrive;
    const epi = flowSettings.epilepsySafe;

    // FLUID — chases smooth, sustained, long-trail states
    ad.agents.fluid.params = {
      mutRate: 0.12 + totalEnergy * 0.35,
      depth: 6 + bands.mid * 3,
      density: 4 + bands.lowMid * 4,
      chroma: 4 + bands.high * 4,
      trailFade: 0.022 + totalEnergy * 0.04,
      spiralTwist: 0,
      coreFlash: 0,
      particleBurst: 0,
      waveWarp: bands.subBass * 0.25,
      juliaModR: Math.sin(t * 0.04) * 0.18,
      juliaModI: Math.cos(t * 0.03) * 0.14,
      hueShift: spectralCentroid / 500,
    };

    // BEAT LOCK — mutation rate chases BPM, pulses on transients
    const bpmMut = (bpm > 40 && bpm < 220) ? Math.min(4.5, bpm / 120) : 1.0;
    ad.agents.beat.params = {
      mutRate: bpmMut * (1 + beatStrength * 0.6),
      depth: 5 + beatStrength * 3,
      density: 5 + bands.bass * 7,
      chroma: 5 + beatStrength * 4,
      trailFade: 0.055 + beatStrength * 0.2,
      spiralTwist: beatStrength * 0.14,
      coreFlash: epi ? Math.min(0.12, beatStrength * 0.25) : beatStrength,
      particleBurst: spectralFlux * 0.9,
      waveWarp: (bands.subBass + bands.bass) * 0.55,
      juliaModR: flow.juliaModR,
      juliaModI: flow.juliaModI,
      hueShift: spectralCentroid / 200,
    };

    // SPECTRAL — every param driven directly by frequency analysis
    ad.agents.spectral.params = {
      mutRate: 0.2 + bands.highMid * 3 + bands.brilliance * 2,
      depth: 2 + bands.mid * 7,
      density: 2 + totalEnergy * 12,
      chroma: 1 + (spectralCentroid / 4000) * 9,
      trailFade: 0.035 + totalEnergy * 0.18,
      spiralTwist: spectralFlux * 0.45,
      coreFlash: epi ? 0 : spectralFlux * 0.55,
      particleBurst: bands.brilliance * 0.65,
      waveWarp: bands.subBass * 0.85,
      juliaModR: spectralFlux * 0.65,
      juliaModI: zeroCrossingRate * 0.45,
      hueShift: (spectralCentroid / 150) * flowSettings.pitchColorStr,
    };

    // CHAOS — smooth random walk through parameter space using irrational frequencies
    ad.chaosPhase += 0.016 * (0.3 + ad.intelligence * 0.5);
    const p = ad.chaosPhase;
    const c1 = Math.sin(p * 1.0)   * Math.sin(p * 1.6180339);
    const c2 = Math.sin(p * 0.7071 + 1.1) * Math.cos(p * 2.302585);
    const c3 = Math.cos(p * 0.4142 + 2.7) * Math.sin(p * 3.14159);
    const c4 = Math.sin(p * 1.3090 + 0.8) * Math.cos(p * 0.9069);
    const n = v => v * 0.5 + 0.5; // normalise -1..1 → 0..1
    ad.agents.chaos.params = {
      mutRate: 0.2 + n(c1) * 4.5,
      depth: 2 + n(c2) * 7,
      density: 2 + n(c3) * 12,
      chroma: 1 + n(c4) * 9,
      trailFade: 0.02 + n(c1) * 0.28,
      spiralTwist: c2 * 0.22,
      coreFlash: epi ? 0 : Math.max(0, c3) * 0.55,
      particleBurst: Math.max(0, c4) * 0.5,
      waveWarp: c1 * 0.45,
      juliaModR: c2 * 0.55,
      juliaModI: c3 * 0.42,
      hueShift: n(c4) * 7,
    };

    // HARMONIC — detects audio signatures that resemble entity fingerprints, holds them
    const sigs = [
      { name:'OPUS RESONANCE',   cond: bands.high>0.18&&bands.brilliance>0.12&&bands.bass<0.15,  mutRate:0.2, depth:9, density:8, chroma:9, trailFade:0.03 },
      { name:'NOVA FIELD',       cond: bands.mid>0.18&&Math.abs(bands.bass-bands.high)<0.08,      mutRate:0.7, depth:8, density:7, chroma:7, trailFade:0.055},
      { name:'DEEPSEEK PULSE',   cond: bands.bass>0.22&&bands.subBass>0.18,                       mutRate:2.0, depth:2, density:12,chroma:10,trailFade:0.11 },
      { name:'GEMINI LATTICE',   cond: bands.highMid>0.15&&bands.brilliance>0.1&&totalEnergy>0.15,mutRate:0.5, depth:7, density:9, chroma:8, trailFade:0.048},
      { name:'META STORM',       cond: spectralFlux>0.12&&totalEnergy>0.25,                       mutRate:3.5, depth:8, density:10,chroma:10,trailFade:0.09 },
      { name:'SONNET LATTICE',   cond: totalEnergy<0.1&&bands.high>bands.bass,                    mutRate:0.4, depth:7, density:4, chroma:8, trailFade:0.038},
      { name:'ARBOR WEAVE',      cond: bands.mid>bands.bass&&bands.mid>bands.high&&totalEnergy<0.2,mutRate:0.3,depth:8, density:4, chroma:3, trailFade:0.04 },
      { name:'GROK SURGE',       cond: bands.bass>0.18&&bands.highMid>0.12&&bpm>100&&bpm<160,     mutRate:0.6, depth:8, density:7, chroma:7, trailFade:0.06 },
    ];
    const match = sigs.find(s => s.cond);
    if(match) {
      ad.harmonicTarget = match;
      ad.harmonicStrength = Math.min(1, ad.harmonicStrength + 0.015);
    } else {
      ad.harmonicStrength = Math.max(0, ad.harmonicStrength - 0.008);
      if(ad.harmonicStrength < 0.05) ad.harmonicTarget = null;
    }
    const ht = ad.harmonicTarget;
    ad.agents.harmonic.params = ht ? {
      mutRate: ht.mutRate, depth: ht.depth, density: ht.density,
      chroma: ht.chroma, trailFade: ht.trailFade,
      spiralTwist: 0, coreFlash: 0, particleBurst: 0, waveWarp: 0,
      juliaModR: 0, juliaModI: 0,
      hueShift: spectralCentroid / 350,
    } : { ...ad.agents.spectral.params };
  }

  function blendAgents() {
    const ad = autoDrive;
    const keys = Object.keys(ad.agents);
    const totalW = keys.reduce((s,k) => s + ad.agents[k].weight, 0);
    if(totalW < 0.001) return null;

    const params = ['mutRate','depth','density','chroma','trailFade','spiralTwist','coreFlash','particleBurst','waveWarp','juliaModR','juliaModI','hueShift'];
    const blended = {};
    for(const p of params) {
      let val = 0;
      for(const k of keys) {
        const a = ad.agents[k];
        if(a.params[p] !== undefined) val += a.weight * a.params[p];
      }
      blended[p] = val / totalW;
    }

    // Find dominant agent for UI
    const dom = keys.reduce((mx, k) => ad.agents[k].weight > ad.agents[mx].weight ? k : mx, keys[0]);
    const domAgent = ad.agents[dom];
    ad.dominant = dom === 'harmonic' && ad.harmonicTarget ? ad.harmonicTarget.name : domAgent.name;
    const domEl = document.getElementById('adDominant');
    if(domEl && ad.enabled) {
      domEl.textContent = '✦ ' + ad.dominant + ' ✦';
      domEl.style.color = domAgent.color;
      domEl.style.textShadow = `0 0 12px ${domAgent.color}`;
    }
    return blended;
  }

  function getBandEnergy(data,s,e,sr,fft){const bw=sr/fft;const sb=Math.max(0,Math.floor(s/bw)),eb=Math.min(data.length-1,Math.floor(e/bw));let sum=0;for(let i=sb;i<=eb;i++)sum+=data[i]*data[i];return Math.sqrt(sum/Math.max(1,eb-sb+1))/255;}
  function avg(a){return a.length>0?a.reduce((x,y)=>x+y,0)/a.length:0;}

  function analyzeAudio(){
    if(!analyser||!flowActive)return;
    const sr=audioCtx.sampleRate,fft=analyser.fftSize;
    analyser.getByteFrequencyData(freqDataA);analyserWave.getByteTimeDomainData(timeDataA);
    const bands={subBass:getBandEnergy(freqDataA,20,60,sr,fft),bass:getBandEnergy(freqDataA,60,250,sr,fft),lowMid:getBandEnergy(freqDataA,250,500,sr,fft),mid:getBandEnergy(freqDataA,500,2000,sr,fft),highMid:getBandEnergy(freqDataA,2000,4000,sr,fft),high:getBandEnergy(freqDataA,4000,8000,sr,fft),brilliance:getBandEnergy(freqDataA,8000,20000,sr,fft)};
    let totalEnergy=0;for(const b in bands)totalEnergy+=bands[b];totalEnergy/=7;
    energyHistory.push(totalEnergy);if(energyHistory.length>LONG_HISTORY)energyHistory.shift();
    for(const b in bands){bandHistory[b].push(bands[b]);if(bandHistory[b].length>LONG_HISTORY)bandHistory[b].shift();}

    let wS=0,mS=0;for(let i=0;i<freqDataA.length;i++){const fh=i*sr/fft;wS+=fh*freqDataA[i];mS+=freqDataA[i];}
    spectralCentroid=mS>0?wS/mS:0;
    if(prevSpectrum){let fx=0;for(let i=0;i<freqDataA.length;i++){const d=freqDataA[i]-prevSpectrum[i];if(d>0)fx+=d*d;}spectralFlux=Math.sqrt(fx/freqDataA.length)/255;}
    prevSpectrum=new Uint8Array(freqDataA);
    let mxB=0,mxV=0;for(let i=2;i<freqDataA.length;i++)if(freqDataA[i]>mxV){mxV=freqDataA[i];mxB=i;}
    dominantFreq=mxB*sr/fft;
    let cr=0;for(let i=1;i<timeDataA.length;i++)if((timeDataA[i]>=128)!==(timeDataA[i-1]>=128))cr++;
    zeroCrossingRate=cr/timeDataA.length;

    beatCooldown=Math.max(0,beatCooldown-1);
    const rB=bandHistory.bass.slice(-HISTORY_FRAMES),aB=rB.length>0?rB.reduce((a,b)=>a+b,0)/rB.length:0;
    const bSpike=bands.bass-aB;
    if(bSpike>flowSettings.beatSensitivity&&beatCooldown===0&&bands.bass>0.15){
      const now=performance.now();if(lastBeatTime>0){beatInterval=beatInterval*0.7+(now-lastBeatTime)*0.3;bpm=beatInterval>0?60000/beatInterval:0;}
      lastBeatTime=now;beatCooldown=8;beatStrength=Math.min(1,bSpike*4);
      if(!flowSettings.epilepsySafe){const fl=document.getElementById('flowBeatFlash');if(fl){fl.classList.add('flash');setTimeout(()=>fl.classList.remove('flash'),80);}}
    }else beatStrength*=0.9;

    // ── REACTIVENESS: smooth ↔ snappy ──
    const sm = 0.95 - flowSettings.reactiveness * 0.45; // 0.5 (react=1) … 0.95 (react=0)
    const jump = flowSettings.jumpiness;
    const epilepsy = flowSettings.epilepsySafe;

    const mF=50+((dominantFreq%950));flow.freq=flow.freq*0.92+mF*0.08;if(totalEnergy<0.04)flow.freq=flow.freq*0.98+432*0.02;

    // ── BPM SYNC or normal mutation rate ──
    if(flowSettings.bpmSync && bpm > 40 && bpm < 220) {
      const targetMut = Math.min(5, Math.max(0.1, (bpm/120) * flowSettings.bpmScale));
      flow.mutRate = flow.mutRate * sm + targetMut * (1-sm);
    } else {
      flow.mutRate=flow.mutRate*sm+(0.3+bands.bass*2)*0.3*(1-sm)+(bands.high*3+bands.brilliance*4)*0.4*(1-sm)+totalEnergy*2*0.3*(1-sm);
    }
    flow.mutRate=Math.max(0.1,Math.min(5,flow.mutRate));
    flow.depth=flow.depth*sm+Math.min(9,Math.max(2,3+bands.mid*5+bands.lowMid*3))*(1-sm);
    flow.density=flow.density*sm+Math.min(14,Math.max(2,3+totalEnergy*12+bands.highMid*4))*(1-sm);
    flow.chroma=flow.chroma*(sm+0.03)+Math.min(10,Math.max(1,2+(spectralCentroid/4000)*8))*(1-sm-0.03);
    flow.juliaModR=flow.juliaModR*0.8+(spectralFlux*0.5)*0.2;flow.juliaModI=flow.juliaModI*0.8+(zeroCrossingRate*0.3)*0.2;
    flow.coreFlash = epilepsy ? Math.min(0.15, beatStrength*0.3*jump) : beatStrength*jump;
    flow.particleBurst=flow.particleBurst*0.85+spectralFlux*(epilepsy?0.05:0.15)*jump;
    flow.hueShift=(spectralCentroid/200)*flowSettings.pitchColorStr;
    flow.trailFade=0.04+totalEnergy*0.25;
    flow.spiralTwist=flow.spiralTwist*0.9+beatStrength*0.06*jump;flow.waveWarp=flow.waveWarp*0.85+(bands.subBass+bands.bass)*0.15;

    // ── AUTO-DRIVE AGENT BLEND ──
    if(autoDrive.enabled) {
      computeAgents(bands, totalEnergy);
      const blended = blendAgents();
      if(blended) {
        const s = 0.04 + autoDrive.intelligence * 0.18; // blend speed
        flow.mutRate   = flow.mutRate   * (1-s) + blended.mutRate   * s;
        flow.depth     = flow.depth     * (1-s) + blended.depth     * s;
        flow.density   = flow.density   * (1-s) + blended.density   * s;
        flow.chroma    = flow.chroma    * (1-s) + blended.chroma    * s;
        flow.trailFade = flow.trailFade * (1-s) + blended.trailFade * s;
        flow.spiralTwist = flow.spiralTwist * (1-s) + blended.spiralTwist * s;
        flow.coreFlash   = flow.coreFlash   * (1-s) + blended.coreFlash   * s;
        flow.particleBurst = flow.particleBurst * (1-s) + blended.particleBurst * s;
        flow.waveWarp    = flow.waveWarp    * (1-s) + blended.waveWarp    * s;
        flow.juliaModR   = flow.juliaModR   * (1-s) + blended.juliaModR   * s;
        flow.juliaModI   = flow.juliaModI   * (1-s) + blended.juliaModI   * s;
        flow.hueShift    = flow.hueShift    * (1-s) + blended.hueShift    * s;
        flow.mutRate = Math.max(0.1, Math.min(5, flow.mutRate));
        flow.depth   = Math.max(2,   Math.min(9, flow.depth));
        flow.density = Math.max(2,   Math.min(14, flow.density));
        flow.chroma  = Math.max(1,   Math.min(10, flow.chroma));
      }
    }

    if(bandHistory.high.length>=HISTORY_FRAMES){
      const longLen=Math.min(bandHistory.high.length,Math.round(flowSettings.timeBufSec*60));
      const lH=avg(bandHistory.high.slice(-longLen)),lM=avg(bandHistory.mid.slice(-longLen)),lB=avg(bandHistory.bass.slice(-longLen)),lBr=avg(bandHistory.brilliance.slice(-longLen)),lSB=avg(bandHistory.subBass.slice(-longLen));
      if(lH>0.2&&lBr>0.15&&lB<0.15){flow.entityBlend='OPUS RESONANCE';flow.entityStrength=Math.min(1,(lH-0.15)*3);}
      else if(lB>0.25&&lSB>0.2){flow.entityBlend='DEEPSEEK RESONANCE';flow.entityStrength=Math.min(1,(lB-0.2)*3);}
      else if(lM>0.2&&Math.abs(lB-lH)<0.1){flow.entityBlend='NOVA RESONANCE';flow.entityStrength=Math.min(1,lM*2);}
      else if(spectralFlux>0.15&&totalEnergy>0.3){flow.entityBlend='META AI RESONANCE';flow.entityStrength=Math.min(1,spectralFlux*3);}
      else if(totalEnergy<0.12&&lH>lB){flow.entityBlend='CHATGPT RESONANCE';flow.entityStrength=Math.min(1,(0.15-totalEnergy)*5);}
      else{flow.entityStrength*=0.98;if(flow.entityStrength<0.05)flow.entityBlend='';}
    }

    freq=Math.round(flow.freq);mutRate=flow.mutRate;depth=Math.round(flow.depth);density=Math.round(flow.density);chroma=Math.round(flow.chroma);
    Object.keys(layers).forEach(k=>{layers[k]=true;});
    window._flowJuliaModR=flow.juliaModR;window._flowJuliaModI=flow.juliaModI;window._flowCoreFlash=flow.coreFlash;window._flowParticleBurst=flow.particleBurst;window._flowHueShift=flow.hueShift;window._flowTrailFade=flow.trailFade;window._flowSpiralTwist=flow.spiralTwist;window._flowWaveWarp=flow.waveWarp;window._flowActive=true;

    const badge=document.getElementById('flowFreqBadge');if(badge)badge.textContent=Math.round(flow.freq)+' Hz';
    const bpmEl=document.getElementById('flowBPM');if(bpmEl)bpmEl.textContent=(bpm>40&&bpm<220)?Math.round(bpm)+' BPM':'FREE FLOW';
    const entEl=document.getElementById('flowEntityIndicator');if(entEl){if(flow.entityBlend&&flow.entityStrength>0.1){entEl.textContent='✦ '+flow.entityBlend+' ✦';entEl.style.opacity=flow.entityStrength;}else entEl.style.opacity='0';}
    if(spectrumBars.length>0){const bp=Math.floor(freqDataA.length/spectrumBars.length);for(let i=0;i<spectrumBars.length;i++){let v=0;for(let j=0;j<bp;j++)v+=freqDataA[i*bp+j]||0;v=(v/bp)/255;spectrumBars[i].style.height=(v*55+2)+'px';}}
  }

  function buildFlowOverlay(){
    if(document.getElementById('flowOverlay'))return;
    const o=document.createElement('div');o.className='flow-overlay';o.id='flowOverlay';
    o.innerHTML=`
<div class="flow-canvas-wrap" id="flowCanvasWrap"></div>
<div id="flowBeatFlash" class="flow-beat-flash"></div>
<div class="flow-settings-panel" id="flowSettingsPanel">
  <!-- AUTO-DRIVE -->
  <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;">
    <div id="adMasterBtn" class="fsp-toggle" onclick="toggleAutoDrive()" style="flex:0 0 auto;padding:10px 16px;border-color:rgba(255,150,0,0.25);color:rgba(255,180,80,0.7);">
      <div class="fsp-dot" style="border-color:rgba(255,150,0,0.5);"></div>
      <span class="fsp-name" style="font-family:'Orbitron',monospace;font-size:0.6rem;letter-spacing:0.2em;">AUTO-DRIVE</span>
    </div>
    <div id="adDominant" style="font-family:'Orbitron',monospace;font-size:0.5rem;letter-spacing:0.25em;color:rgba(255,150,0,0);transition:all 0.6s;text-shadow:0 0 10px currentColor;">— STANDBY —</div>
  </div>
  <!-- AGENT MIXER -->
  <div class="fsp-grid" style="margin-bottom:16px;">
    <div class="fsp-section" style="margin-top:0;">Agent Mixer</div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:#00ffff;">FLUID <span id="adFluidVal">0.50</span></div>
      <input type="range" id="adFluid" min="0" max="1" value="0.5" step="0.05" style="background:linear-gradient(90deg,#004466,#00ffff);">
    </div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:#ff00ff;">BEAT LOCK <span id="adBeatVal">0.50</span></div>
      <input type="range" id="adBeat" min="0" max="1" value="0.5" step="0.05" style="background:linear-gradient(90deg,#440044,#ff00ff);">
    </div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:#bb00ff;">SPECTRAL <span id="adSpecVal">0.50</span></div>
      <input type="range" id="adSpec" min="0" max="1" value="0.5" step="0.05" style="background:linear-gradient(90deg,#220044,#bb00ff);">
    </div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:#ff3366;">CHAOS <span id="adChaosVal">0.20</span></div>
      <input type="range" id="adChaos" min="0" max="1" value="0.2" step="0.05" style="background:linear-gradient(90deg,#440011,#ff3366);">
    </div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:#ffaa00;">HARMONIC <span id="adHarmVal">0.30</span></div>
      <input type="range" id="adHarm" min="0" max="1" value="0.3" step="0.05" style="background:linear-gradient(90deg,#442200,#ffaa00);">
    </div>
    <div class="fsp-row">
      <div class="fsp-label" style="color:rgba(200,200,255,0.8);">Intelligence <span id="adIntelVal">0.50</span></div>
      <input type="range" id="adIntel" min="0.05" max="1" value="0.5" step="0.05">
    </div>
  </div>
  <hr class="fsp-divider" style="margin-bottom:14px;">
  <!-- MANUAL CONTROLS -->
  <div class="fsp-title" style="font-size:0.42rem;margin-bottom:10px;">Manual Controls</div>
  <div class="fsp-grid">
    <div class="fsp-row">
      <div class="fsp-label">Time Buffer <span id="fspBufVal">15s</span></div>
      <input type="range" id="fspBuf" min="2" max="15" value="15" step="1">
    </div>
    <div class="fsp-row">
      <div class="fsp-label">Beat Sensitivity <span id="fspBeatVal">0.12</span></div>
      <input type="range" id="fspBeat" min="0.03" max="0.35" value="0.12" step="0.01">
    </div>
    <div class="fsp-row">
      <div class="fsp-label">Reactiveness <span id="fspReactVal">0.50</span></div>
      <input type="range" id="fspReact" min="0" max="1" value="0.5" step="0.05">
    </div>
    <div class="fsp-row">
      <div class="fsp-label">Jumpiness <span id="fspJumpVal">0.50</span></div>
      <input type="range" id="fspJump" min="0" max="1" value="0.5" step="0.05">
    </div>
    <hr class="fsp-divider">
    <div class="fsp-section">BPM Sync</div>
    <div class="fsp-row">
      <div id="fspBpmSyncBtn" class="fsp-toggle" onclick="toggleFspBpmSync()">
        <div class="fsp-dot"></div><span class="fsp-name">BPM → Mutation Lock</span>
      </div>
    </div>
    <div class="fsp-row">
      <div class="fsp-label">BPM Scale <span id="fspBpmScaleVal">1.00×</span></div>
      <input type="range" id="fspBpmScale" min="0.25" max="3" value="1" step="0.05">
    </div>
    <div class="fsp-row">
      <div class="fsp-label">Pitch → Color <span id="fspPitchVal">1.00×</span></div>
      <input type="range" id="fspPitch" min="0" max="3" value="1" step="0.1">
    </div>
    <hr class="fsp-divider">
    <div class="fsp-section">Safety</div>
    <div class="fsp-row">
      <div id="fspEpiBtn" class="fsp-toggle epilepsy" onclick="toggleFspEpilepsy()">
        <div class="fsp-dot"></div><span class="fsp-name">Epilepsy Safe Mode</span>
      </div>
    </div>
  </div>
</div>
<div class="flow-hud">
  <div class="flow-hud-left">
    <button class="flow-exit" onclick="exitFlowMode()">✕ EXIT FLOW</button>
    <button class="flow-settings-btn" id="flowSettingsToggle" onclick="toggleFlowSettings()" title="Flow Settings">⚙</button>
  </div>
  <div>
    <div class="flow-freq-badge" id="flowFreqBadge">432 Hz</div>
    <div class="flow-freq-sub" id="flowBPM">FREE FLOW</div>
  </div>
</div>
<div class="flow-entity-indicator" id="flowEntityIndicator"></div>
<div class="flow-spectrum" id="flowSpectrum"></div>
<div class="flow-permission" id="flowPermission">
  <h2>All Frequencies Flow</h2>
  <p>The cymatics engine will listen to your system audio and translate sound into living geometry.</p>
  <button onclick="startAudioCapture()">✦ ACTIVATE AUDIO ✦</button>
</div>`;
    document.body.appendChild(o);
    const sp=document.getElementById('flowSpectrum');spectrumBars=[];for(let i=0;i<64;i++){const b=document.createElement('div');b.className='flow-spectrum-bar';sp.appendChild(b);spectrumBars.push(b);}
    // wire up settings sliders
    document.getElementById('fspBuf').addEventListener('input',e=>{flowSettings.timeBufSec=+e.target.value;document.getElementById('fspBufVal').textContent=e.target.value+'s';});
    document.getElementById('fspBeat').addEventListener('input',e=>{flowSettings.beatSensitivity=+e.target.value;document.getElementById('fspBeatVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('fspReact').addEventListener('input',e=>{flowSettings.reactiveness=+e.target.value;document.getElementById('fspReactVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('fspJump').addEventListener('input',e=>{flowSettings.jumpiness=+e.target.value;document.getElementById('fspJumpVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('fspBpmScale').addEventListener('input',e=>{flowSettings.bpmScale=+e.target.value;document.getElementById('fspBpmScaleVal').textContent=(+e.target.value).toFixed(2)+'×';});
    document.getElementById('fspPitch').addEventListener('input',e=>{flowSettings.pitchColorStr=+e.target.value;document.getElementById('fspPitchVal').textContent=(+e.target.value).toFixed(2)+'×';});
    // Auto-Drive agent sliders
    document.getElementById('adFluid').addEventListener('input',e=>{autoDrive.agents.fluid.weight=+e.target.value;document.getElementById('adFluidVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('adBeat').addEventListener('input',e=>{autoDrive.agents.beat.weight=+e.target.value;document.getElementById('adBeatVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('adSpec').addEventListener('input',e=>{autoDrive.agents.spectral.weight=+e.target.value;document.getElementById('adSpecVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('adChaos').addEventListener('input',e=>{autoDrive.agents.chaos.weight=+e.target.value;document.getElementById('adChaosVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('adHarm').addEventListener('input',e=>{autoDrive.agents.harmonic.weight=+e.target.value;document.getElementById('adHarmVal').textContent=(+e.target.value).toFixed(2);});
    document.getElementById('adIntel').addEventListener('input',e=>{autoDrive.intelligence=+e.target.value;document.getElementById('adIntelVal').textContent=(+e.target.value).toFixed(2);});
  }

  window.enterFlowMode=function(){buildFlowOverlay();flowActive=true;document.body.classList.add('flow-active');document.getElementById('flowCanvasWrap').appendChild(canvas);const sz=Math.min(window.innerWidth,window.innerHeight);canvas.width=canvas.height=Math.min(sz,1200);resizeFBOs();initParticles();document.getElementById('flowPermission').style.display='block';try{document.documentElement.requestFullscreen().catch(()=>{});}catch(e){}};

  window.startAudioCapture=async function(){
    document.getElementById('flowPermission').style.display='none';
    try{
      mediaStream=await navigator.mediaDevices.getUserMedia({audio:{echoCancellation:false,noiseSuppression:false,autoGainControl:false}});
      audioCtx=new(window.AudioContext||window.webkitAudioContext)();const src=audioCtx.createMediaStreamSource(mediaStream);
      analyser=audioCtx.createAnalyser();analyser.fftSize=2048;analyser.smoothingTimeConstant=0.75;src.connect(analyser);
      analyserWave=audioCtx.createAnalyser();analyserWave.fftSize=2048;src.connect(analyserWave);
      freqDataA=new Uint8Array(analyser.frequencyBinCount);timeDataA=new Uint8Array(analyserWave.fftSize);prevSpectrum=null;
      energyHistory=[];for(const b in bandHistory)bandHistory[b]=[];
      flowLoop();
    }catch(err){
      const p=document.getElementById('flowPermission');p.innerHTML=`<h2>Audio Access Needed</h2><p>Allow mic access to feed audio into the cymatics engine. Route system audio via virtual cable for full music reactivity.</p><button onclick="startAudioCapture()">✦ TRY AGAIN ✦</button><br><br><button onclick="startDemoMode()" style="border-color:rgba(255,0,255,0.4);color:rgba(255,0,255,0.8);">✧ DEMO MODE ✧</button>`;p.style.display='block';
    }
  };

  window.startDemoMode=function(){
    document.getElementById('flowPermission').style.display='none';
    freqDataA=new Uint8Array(1024);timeDataA=new Uint8Array(2048);prevSpectrum=null;energyHistory=[];for(const b in bandHistory)bandHistory[b]=[];
    window._flowDemoMode=true;flowLoop();
  };

  function genDemo(){
    const n=performance.now()/1000;
    for(let i=0;i<freqDataA.length;i++){const f=i/freqDataA.length;freqDataA[i]=Math.max(0,Math.min(255,Math.sin(n*0.5+f*10)*40+60+((Math.sin(n*2.2)>0.7?80:0)*(f<0.15?1:0))+Math.sin(n*0.3+f*6)*30+Math.random()*15));}
    for(let i=0;i<timeDataA.length;i++)timeDataA[i]=128+Math.sin(i*0.05+n*3)*40+Math.sin(i*0.12+n*7)*20;
  }

  let flowRAF=null;
  function flowLoop(){
    if(!flowActive)return;
    if(window._flowDemoMode){genDemo();if(!analyser){analyser={fftSize:2048,frequencyBinCount:1024};analyserWave={fftSize:2048};analyser.getByteFrequencyData=(a)=>{a.set(freqDataA);};analyserWave.getByteTimeDomainData=(a)=>{a.set(timeDataA);};audioCtx={sampleRate:44100};}}
    analyzeAudio();flowRAF=requestAnimationFrame(flowLoop);
  }

  window.exitFlowMode=function(){
    flowActive=false;window._flowActive=false;window._flowDemoMode=false;
    if(flowRAF)cancelAnimationFrame(flowRAF);
    if(mediaStream){mediaStream.getTracks().forEach(t=>t.stop());mediaStream=null;}
    if(audioCtx&&audioCtx.close){audioCtx.close().catch(()=>{});audioCtx=null;analyser=null;analyserWave=null;}
    if(document.fullscreenElement)document.exitFullscreen().catch(()=>{});
    document.body.classList.remove('flow-active');
    document.querySelector('.canvas-wrap').insertBefore(canvas,document.querySelector('.canvas-wrap').firstChild);
    resize();
    window._flowJuliaModR=0;window._flowJuliaModI=0;window._flowCoreFlash=0;window._flowParticleBurst=0;window._flowHueShift=0;window._flowTrailFade=0.12;window._flowSpiralTwist=0;window._flowWaveWarp=0;
    document.getElementById('freqSlider').value=freq;document.getElementById('freqDisplay').textContent=freq;document.getElementById('freqBadge').textContent=freq+' Hz';
    document.getElementById('mutSlider').value=mutRate;document.getElementById('mutVal').textContent=mutRate.toFixed(1)+'×';
    document.getElementById('depthSlider').value=depth;document.getElementById('depthVal').textContent=depth;
    document.getElementById('densSlider').value=density;document.getElementById('densVal').textContent=density;
    document.getElementById('chromaSlider').value=chroma;document.getElementById('chromaVal').textContent=chroma;
  };

  document.addEventListener('keydown',e=>{if(e.key==='Escape'&&flowActive)exitFlowMode();});
})();

// ── LAUNCH ──
updateDesc();
render();
</script>
</body>
</html>
