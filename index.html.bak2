function rewindTimer() {
  // Rewind 5 effective seconds
  timerStart = Math.min(Date.now(), timerStart + (5000 / speedMultiplier));
  const el = document.getElementById('obsTimer');
  if(el) el.classList.remove('pulse');
}

function skipToTime() {
  const raw = document.getElementById('skipInput').value.trim();
  let totalSeconds = 0;
  if(raw.includes(':')) {
    const parts = raw.split(':');
    totalSeconds = parseInt(parts[0]||0)*60 + parseInt(parts[1]||0);
  } else {
    totalSeconds = parseInt(raw)||0;
  }
  timerStart = Date.now() - (totalSeconds / speedMultiplier) * 1000;
  const el = document.getElementById('obsTimer');
  if(el) el.classList.remove('pulse');
  document.getElementById('skipInput').value = '';
}

updateDesc();
render();
</script>
